{
  "info": {
    "_postman_id": "5ec43a4f-3e3f-47f2-8a2f-b4ec37f2b58f",
    "name": "Messaging Inbox API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección Postman para el proyecto Messaging Inbox (Laravel + JWT). Incluye autenticación, usuarios, conversaciones, mensajes y contador de no leídos."
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "token", "value": "" },
    { "key": "conversation_id", "value": "1" },
    { "key": "other_user_id", "value": "2" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "",
                  "if (data.access_token) {",
                  "    pm.collectionVariables.set('token', data.access_token);",
                  "}",
                  "",
                  "if (data.user && data.user.id) {",
                  "    pm.collectionVariables.set('current_user_id', String(data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@messaging-inbox.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Inicia sesión con JWT. Guarda automáticamente el access_token en la variable de colección `token`."
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Devuelve los datos del usuario autenticado."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Cierra la sesión JWT actual."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "Lista usuarios disponibles para crear nuevas conversaciones."
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/conversations?search=&status=&page=1&per_page=10",
              "host": ["{{base_url}}"],
              "path": ["conversations"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "status", "value": "" },
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            },
            "description": "Listado paginado de conversaciones con búsqueda y filtro por estado."
          }
        },
        {
          "name": "Unread Count",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/unread-count",
              "host": ["{{base_url}}"],
              "path": ["conversations", "unread-count"]
            },
            "description": "Devuelve el contador total de mensajes no leídos del usuario autenticado."
          }
        },
        {
          "name": "Conversation Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}"]
            },
            "description": "Detalle de una conversación con sus participantes y mensajes."
          }
        },
        {
          "name": "Create Conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Conversación creada', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.data && data.data.id) {",
                  "    pm.collectionVariables.set('conversation_id', String(data.data.id));",
                  "} else if (data.id) {",
                  "    pm.collectionVariables.set('conversation_id', String(data.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Nuevo tema de soporte\",\n  \"participant_ids\": [{{other_user_id}}],\n  \"message\": \"Hola, necesito apoyo con este tema.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations",
              "host": ["{{base_url}}"],
              "path": ["conversations"]
            },
            "description": "Crea una conversación nueva y guarda el ID resultante en `conversation_id`."
          }
        },
        {
          "name": "Mark Conversation as Read",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "read"]
            },
            "description": "Marca como leída la conversación indicada."
          }
        },
        {
          "name": "Reply to Conversation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Esta es una respuesta de seguimiento.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"]
            },
            "description": "Envía un nuevo mensaje dentro de la conversación indicada."
          }
        }
      ]
    }
  ]
}
